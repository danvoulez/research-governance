set shell := ["bash", "-lc"]

# --- Rust quality ---

fmt:
  cargo fmt --all

fmt-check:
  cargo fmt --all -- --check

check:
  cargo check --workspace

lint:
  cargo clippy --workspace --all-targets --all-features -- -D warnings

test:
  cargo test --workspace

ci: fmt-check lint test

# --- Cycle governance ---

cycle-new *ARGS:
  ./scripts/new_cycle_scaffold.sh {{ARGS}}

cycle-refresh *ARGS:
  ./scripts/refresh_cycle_governance.sh {{ARGS}}

cycle-verify *ARGS:
  ./scripts/verify_cycle_progress.sh {{ARGS}}

cycle-compare-draft CYCLE_DIR REPORT1 REPORT2 *ARGS:
  cargo run -p manager-plane --example draft_governance_notes -- comparison \
    --run {{REPORT1}} --run {{REPORT2}} \
    --out {{CYCLE_DIR}}/COMPARATIVE_NOTE.auto.md {{ARGS}}

cycle-decision-draft CYCLE_DIR CYCLE_ID *REPORTS:
  #!/usr/bin/env bash
  args=""
  for r in {{REPORTS}}; do args="$args --report $r"; done
  cargo run -p manager-plane --example draft_governance_notes -- decision \
    --cycle-id {{CYCLE_ID}} $args \
    --out {{CYCLE_DIR}}/DECISION_NOTE.auto.md

cycle-triage CYCLE_DIR:
  @echo "Triage state for {{CYCLE_DIR}}:"
  @grep -E "triage_state:|lifecycle_state:" {{CYCLE_DIR}}/CYCLE_README.md 2>/dev/null || echo "  No triage state found. Update CYCLE_README.md."
  @echo ""
  @echo "STATUS_MATRIX:"
  @cat {{CYCLE_DIR}}/STATUS_MATRIX.auto.md 2>/dev/null || echo "  No STATUS_MATRIX.auto.md found. Run cycle-refresh first."

cycle-freeze-check CYCLE_DIR:
  @echo "Freeze state for {{CYCLE_DIR}}:"
  @grep -E "frozen_now:|freeze_state:" {{CYCLE_DIR}}/CYCLE_README.md 2>/dev/null || echo "  No freeze info found."
  @echo ""
  @echo "Checking run contract compliance..."
  @ls {{CYCLE_DIR}}/*.auto.md 2>/dev/null || echo "  No auto docs found."

sync-experiment-docs:
  ./scripts/sync_experiment_docs.sh

# --- Run validation ---

run-completeness CYCLE_DIR:
  #!/usr/bin/env bash
  set -euo pipefail
  echo "=== Run completeness check for {{CYCLE_DIR}} ==="
  echo ""

  l1_fails=0
  l1_warns=0
  l2_fails=0
  l2_caveats=0
  l3_blocks=0
  l3_caveats=0

  echo "## Level 1 — Artifact completeness"
  echo "   (RUN_CONTRACT: minimum artifacts for a valid run)"
  echo ""

  # manifest
  if compgen -G "benchmarks/manifests/*.json" > /dev/null 2>&1; then
    echo "  [ok] manifest found"
  else
    echo "  [FAIL] no manifest found in benchmarks/manifests/"
    l1_fails=$((l1_fails + 1))
  fi

  # raw output
  if compgen -G "{{CYCLE_DIR}}/raw_output*" > /dev/null 2>&1 || compgen -G "{{CYCLE_DIR}}/raw-output*" > /dev/null 2>&1; then
    echo "  [ok] raw output found"
  else
    echo "  [FAIL] no raw output in {{CYCLE_DIR}}/"
    l1_fails=$((l1_fails + 1))
  fi

  # report
  if compgen -G "{{CYCLE_DIR}}/*report*" > /dev/null 2>&1 || compgen -G "{{CYCLE_DIR}}/*REPORT*" > /dev/null 2>&1; then
    echo "  [ok] report found"
  else
    echo "  [FAIL] no report in {{CYCLE_DIR}}/"
    l1_fails=$((l1_fails + 1))
  fi

  # version registry
  if [ -f "benchmarks/version_registry.json" ]; then
    echo "  [ok] version_registry.json exists"
  else
    echo "  [FAIL] no benchmarks/version_registry.json"
    l1_fails=$((l1_fails + 1))
  fi

  # checklist and canonical check
  if [ -f "{{CYCLE_DIR}}/PRE_CYCLE_CHECKLIST.auto.md" ]; then
    echo "  [ok] PRE_CYCLE_CHECKLIST.auto.md exists"
  else
    echo "  [warn] no PRE_CYCLE_CHECKLIST.auto.md"
    l1_warns=$((l1_warns + 1))
  fi

  if [ -f "{{CYCLE_DIR}}/CANONICAL_COMPLETENESS_CHECK.auto.md" ]; then
    echo "  [ok] CANONICAL_COMPLETENESS_CHECK.auto.md exists"
  else
    echo "  [warn] no CANONICAL_COMPLETENESS_CHECK.auto.md"
    l1_warns=$((l1_warns + 1))
  fi

  echo ""
  if [ $l1_fails -eq 0 ]; then
    echo "  Level 1 result: PASS"
    [ $l1_warns -gt 0 ] && echo "  ($l1_warns warnings)"
  else
    echo "  Level 1 result: FAIL ($l1_fails missing artifacts)"
  fi

  echo ""
  echo "## Level 2 — Method completeness"
  echo "   (session log, patch ledger, cycle readme, methodology context)"
  echo ""

  # cycle readme
  if [ -f "{{CYCLE_DIR}}/CYCLE_README.md" ]; then
    echo "  [ok] CYCLE_README.md exists"
    # check if frozen contract is filled
    if grep -q "frozen_now:" "{{CYCLE_DIR}}/CYCLE_README.md" 2>/dev/null; then
      echo "  [ok] frozen contract section present"
    else
      echo "  [caveat] frozen contract section missing or empty"
      l2_caveats=$((l2_caveats + 1))
    fi
  else
    echo "  [FAIL] no CYCLE_README.md"
    l2_fails=$((l2_fails + 1))
  fi

  # session logs
  if [ -d "{{CYCLE_DIR}}/sessions" ] && compgen -G "{{CYCLE_DIR}}/sessions/*.md" > /dev/null 2>&1; then
    count=$(ls -1 "{{CYCLE_DIR}}/sessions/"*.md 2>/dev/null | wc -l | tr -d ' ')
    echo "  [ok] $count session log(s) found"
  else
    echo "  [caveat] no session logs in {{CYCLE_DIR}}/sessions/"
    l2_caveats=$((l2_caveats + 1))
  fi

  # patch ledger
  if [ -d "{{CYCLE_DIR}}/patches" ] && compgen -G "{{CYCLE_DIR}}/patches/*.md" > /dev/null 2>&1; then
    count=$(ls -1 "{{CYCLE_DIR}}/patches/"*.md 2>/dev/null | wc -l | tr -d ' ')
    echo "  [ok] $count patch ledger(s) found"
  else
    echo "  [info] no patch ledgers (ok if no code was changed)"
  fi

  # experiment charter and methodology
  if [ -f "{{CYCLE_DIR}}/EXPERIMENT_CHARTER.md" ]; then
    echo "  [ok] EXPERIMENT_CHARTER.md exists"
  else
    echo "  [caveat] no EXPERIMENT_CHARTER.md"
    l2_caveats=$((l2_caveats + 1))
  fi

  if [ -f "{{CYCLE_DIR}}/METHODOLOGY_SPEC.md" ]; then
    echo "  [ok] METHODOLOGY_SPEC.md exists"
  else
    echo "  [caveat] no METHODOLOGY_SPEC.md"
    l2_caveats=$((l2_caveats + 1))
  fi

  echo ""
  if [ $l2_fails -eq 0 ] && [ $l2_caveats -eq 0 ]; then
    echo "  Level 2 result: PASS"
  elif [ $l2_fails -eq 0 ]; then
    echo "  Level 2 result: PASS WITH CAVEATS ($l2_caveats caveats)"
  else
    echo "  Level 2 result: FAIL ($l2_fails missing, $l2_caveats caveats)"
  fi

  echo ""
  echo "## Level 3 — Comparison readiness"
  echo "   (comparative note, status matrix, baseline identified)"
  echo ""

  # comparative note
  if [ -f "{{CYCLE_DIR}}/COMPARATIVE_NOTE.auto.md" ] || [ -f "{{CYCLE_DIR}}/COMPARATIVE_NOTE.md" ]; then
    echo "  [ok] comparative note exists"
  else
    echo "  [block] no comparative note — comparison not possible yet"
    l3_blocks=$((l3_blocks + 1))
  fi

  # status matrix
  if [ -f "{{CYCLE_DIR}}/STATUS_MATRIX.auto.md" ]; then
    echo "  [ok] STATUS_MATRIX.auto.md exists"
  else
    echo "  [block] no STATUS_MATRIX.auto.md"
    l3_blocks=$((l3_blocks + 1))
  fi

  # decision note
  if [ -f "{{CYCLE_DIR}}/DECISION_NOTE.auto.md" ] || [ -f "{{CYCLE_DIR}}/DECISION_NOTE.md" ]; then
    echo "  [ok] decision note exists"
  else
    echo "  [caveat] no decision note yet"
    l3_caveats=$((l3_caveats + 1))
  fi

  # verify trace
  if [ -f "{{CYCLE_DIR}}/VERIFY_STATUS.auto.md" ]; then
    echo "  [ok] VERIFY_STATUS.auto.md exists"
  else
    echo "  [caveat] no verify trace"
    l3_caveats=$((l3_caveats + 1))
  fi

  echo ""
  if [ $l3_blocks -eq 0 ] && [ $l3_caveats -eq 0 ]; then
    echo "  Level 3 result: PASS"
  elif [ $l3_blocks -eq 0 ]; then
    echo "  Level 3 result: PASS WITH CAVEATS ($l3_caveats caveats)"
  else
    echo "  Level 3 result: FAIL ($l3_blocks blocking, $l3_caveats caveats)"
  fi

  echo ""
  echo "=== Summary ==="
  total_fails=$((l1_fails + l2_fails + l3_blocks))
  total_caveats=$((l1_warns + l2_caveats + l3_caveats))
  if [ $total_fails -eq 0 ] && [ $total_caveats -eq 0 ]; then
    echo "  Overall: PASS"
  elif [ $total_fails -eq 0 ]; then
    echo "  Overall: PASS WITH CAVEATS ($total_caveats total caveats)"
  else
    echo "  Overall: FAIL ($total_fails failures, $total_caveats caveats)"
  fi

run-contract-check CYCLE_DIR:
  @echo "Run contract check (see docs/RUN_CONTRACT.md)"
  @echo ""
  @just run-completeness {{CYCLE_DIR}}

run-lifecycle-update:
  @echo "Run lifecycle states are tracked in CYCLE_README.md and STATUS_MATRIX.auto.md."
  @echo "See docs/RUN_LIFECYCLE.md for valid transitions."
  @echo "Update lifecycle_state in the relevant template manually or via cycle-refresh."

# --- Agent session tracking ---

agent-session-open SESSION_ID CYCLE_ID AGENT_ID OBJECTIVE:
  #!/usr/bin/env bash
  dir="docs/experiments/{{CYCLE_ID}}/sessions"
  mkdir -p "$dir"
  cat > "$dir/{{SESSION_ID}}.md" <<TEMPLATE
  # Agent Session Log: {{SESSION_ID}}

  ## Session metadata
  - session_id: {{SESSION_ID}}
  - cycle_id: {{CYCLE_ID}}
  - opened_at: $(date -u +"%Y-%m-%dT%H:%M:%SZ")
  - closed_at:
  - status: open
  - agent_or_tool_identity: {{AGENT_ID}}
  - operator_context: local IDE

  ## Trace metadata
  - trace_id:
  - parent_session_id:
  - step_id:
  - tool_call_id:

  ## Objective
  - objective: {{OBJECTIVE}}
  - requested_by: human
  - related_hypothesis_or_task:

  ## Files touched

  ## Commands run

  ## Output artifacts

  ## Decisions and escalations

  ## Integrity notes
  - manifest_used:
  - freeze_state_seen:
  - did_methodology_change: no

  ## Closing summary
  - summary_of_work:
  - next_legitimate_action:
  - handoff_notes:
  TEMPLATE
  echo "Session log created: $dir/{{SESSION_ID}}.md"

agent-session-step SESSION_FILE STEP COMMAND RESULT:
  #!/usr/bin/env bash
  echo "" >> {{SESSION_FILE}}
  echo "### Step: {{STEP}}" >> {{SESSION_FILE}}
  echo "- command: {{COMMAND}}" >> {{SESSION_FILE}}
  echo "- result: {{RESULT}}" >> {{SESSION_FILE}}
  echo "- timestamp: $(date -u +"%Y-%m-%dT%H:%M:%SZ")" >> {{SESSION_FILE}}
  echo "Step appended to {{SESSION_FILE}}"

agent-session-close SESSION_FILE SUMMARY:
  #!/usr/bin/env bash
  sed -i '' "s/- status: open/- status: closed/" {{SESSION_FILE}} 2>/dev/null || sed -i "s/- status: open/- status: closed/" {{SESSION_FILE}}
  sed -i '' "s/- closed_at:/- closed_at: $(date -u +"%Y-%m-%dT%H:%M:%SZ")/" {{SESSION_FILE}} 2>/dev/null || sed -i "s/- closed_at:/- closed_at: $(date -u +"%Y-%m-%dT%H:%M:%SZ")/" {{SESSION_FILE}}
  sed -i '' "s/- summary_of_work:/- summary_of_work: {{SUMMARY}}/" {{SESSION_FILE}} 2>/dev/null || sed -i "s/- summary_of_work:/- summary_of_work: {{SUMMARY}}/" {{SESSION_FILE}}
  echo "Session closed: {{SESSION_FILE}}"

patch-ledger-add CYCLE_ID PATCH_ID HYPOTHESIS DIMENSION IMPACT:
  #!/usr/bin/env bash
  dir="docs/experiments/{{CYCLE_ID}}/patches"
  mkdir -p "$dir"
  cat > "$dir/{{PATCH_ID}}.md" <<TEMPLATE
  # Patch Ledger: {{PATCH_ID}}

  ## Patch entry
  - patch_id: {{PATCH_ID}}
  - related_cycle: {{CYCLE_ID}}
  - opened_at: $(date -u +"%Y-%m-%dT%H:%M:%SZ")
  - status: proposed

  ## Hypothesis of patch
  - hypothesis_of_patch: {{HYPOTHESIS}}
  - expected_effect:

  ## Affected dimension
  - affected_dimension: {{DIMENSION}}
  - version_impact: {{IMPACT}}

  ## Touched files

  ## Evidence that motivated patch

  ## Execution and resulting status
  - resulting_status:
  - followup_required: no

  ## Methodological impact
  - rollback_needed: no
  - invalidates_previous_runs: no
  - requires_new_baseline: no

  ## Human review
  - requires_human_review: no
  TEMPLATE
  echo "Patch ledger created: $dir/{{PATCH_ID}}.md"
